# Server
PORT=5000
NODE_ENV=development

# Database (PostgreSQL - Render.com)
# On Render, copy the "Internal Database URL" (or "External" if connecting
# from outside Render) from your Postgres instance's dashboard into DATABASE_URL.
# Example: postgres://user:password@host/dbname
DATABASE_URL=postgres://user:password@localhost:5432/people_esheba
# Set to true only if your provider needs SSL and it's not auto-detected
DB_SSL=false

# JWT
JWT_SECRET=your_super_secret_jwt_key_change_this_in_production
JWT_EXPIRES_IN=7d

# CORS
FRONTEND_URL=http://localhost:5173

# File Upload
MAX_FILE_SIZE=5242880
UPLOAD_DIR=uploads
